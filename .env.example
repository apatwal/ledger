# Copy this file to `.env` and fill in your key. `.env` is gitignored.
# Get a free key at https://aistudio.google.com  ("Get API key")
GEMINI_API_KEY=

# Optional: override the model (defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ── Plaid integration (v8) ────────────────────────────────────────────────────
# Get sandbox keys at https://dashboard.plaid.com. With CLIENT_ID/SECRET unset,
# the app runs normally and all /api/plaid/* network endpoints return 503.
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox (default) | development | production
PLAID_ENV=sandbox
# Comma-separated Plaid products and country codes.
PLAID_PRODUCTS=transactions,investments
PLAID_COUNTRY_CODES=US
# Optional OAuth redirect URI registered in the Plaid dashboard.
PLAID_REDIRECT_URI=
# Optional shared secret required (as header X-Plaid-Sync-Token) to call
# POST /api/plaid/sync-all — use it for a Render Cron Job.
PLAID_SYNC_TOKEN=
# Optional: when set to a positive int AND Plaid is configured, run an in-process
# scheduler that syncs every N minutes (for always-on instances).
PLAID_AUTOSYNC_INTERVAL_MINUTES=

# ── Performance / Neon cold starts ────────────────────────────────────────────
# Neon Postgres scales its compute to zero when idle, so the first request after
# a lull stalls for several seconds. When set to a positive int AND DATABASE_URL
# is Postgres, run an in-process job that pings `SELECT 1` every N seconds to keep
# Neon warm while THIS server process is alive (e.g. 240 = every 4 min). Unset/0
# or on SQLite → disabled. Does NOT help while the host itself is asleep (Render
# free tier). Optional pool overrides: DB_POOL_SIZE (5), DB_MAX_OVERFLOW (5),
# DB_POOL_RECYCLE (300s) — Postgres only.
DB_KEEPALIVE_SECONDS=

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# GATED: with CLERK_ISSUER (or CLERK_JWKS_URL) UNSET, auth is DISABLED and every
# /api route is open (local dev + tests). Set the issuer to turn auth ON: all
# /api routes then require a valid Clerk session JWT. /api/health and the SPA
# stay open; the Plaid sync-all cron stays reachable via X-Plaid-Sync-Token.
# Your Clerk Frontend API URL, e.g. https://<subdomain>.clerk.accounts.dev
CLERK_ISSUER=
# Optional: overrides the JWKS endpoint (defaults to ${CLERK_ISSUER}/.well-known/jwks.json)
CLERK_JWKS_URL=
# Optional: Clerk secret key (sk_...) — enables server-side email lookup when the
# session token has no email claim.
CLERK_SECRET_KEY=
# Comma-separated email allowlist (case-insensitive). Empty = any authenticated
# Clerk user is allowed. For single-user, set this to your email.
ALLOWED_EMAILS=
# FRONTEND key (Vite): Clerk publishable key (pk_...). Consumed by the React app,
# not the API. Set it on the frontend build/host.
VITE_CLERK_PUBLISHABLE_KEY=
